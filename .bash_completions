# Custom TAB completions for Ahmed's aliases & functions.
# Sourced from ~/.bashrc AFTER bash-completion, fzf, .bash_aliases, .bash_functions
# are all loaded. Order matters: bash-completion defines _completion_loader.

# ----------------------------------------------------------------------------
# _alias_completion REAL_CMD ALIAS1 [ALIAS2 ...]
# Make one or more aliases share a real command's full TAB completion.
# Loads REAL_CMD's completion via bash-completion's lazy loader, then clones
# its `complete` registration onto each alias. E.g. `gut`, `got`, ... complete
# exactly like `git`.
# ----------------------------------------------------------------------------
_alias_completion() {
    local real="$1"; shift
    [ $# -eq 0 ] && return 0
    type _completion_loader >/dev/null 2>&1 && _completion_loader "$real" 2>/dev/null
    local comp
    comp="$(complete -p "$real" 2>/dev/null)" || return 0
    local opts="${comp% *}"                    # strip the trailing command name
    # shellcheck disable=SC2086
    eval "$opts" "$@" 2>/dev/null
}

# git typo-aliases -> full git completion (subcommands, branches, remotes, ...)
_alias_completion git   gut ggit got gitt giot igt gti

# docker typo-aliases -> full docker completion (containers, images, commands)
_alias_completion docker docke dockerr docer dockeg dockef docked docket

# pushy forwards "$@" to `git push` per remote -> reuse git completion (refspecs)
_alias_completion git pushy

# ----------------------------------------------------------------------------
# ssh: plain TAB -> bash-completion's _ssh (options + ~/.ssh/config hosts);
# `ssh **<TAB>` -> fzf fuzzy host picker.
# fzf replaces ssh's completion (_fzf_complete_ssh) but, because bash-completion
# is lazy-loaded, finds no original to delegate to on a plain TAB — so plain
# `ssh <TAB>` would return nothing. This wrapper restores plain-TAB behavior by
# calling bash-completion's _ssh directly, while still yielding to fzf for `**`.
# ----------------------------------------------------------------------------
_ssh_smart() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local trigger=${FZF_COMPLETION_TRIGGER-'**'}
    if [[ $cur == *"$trigger" ]] && declare -F _fzf_complete_ssh >/dev/null 2>&1; then
        _fzf_complete_ssh; return $?
    fi
    # Delegate to bash-completion's ssh completion — _comp_cmd_ssh reads
    # ~/.ssh/config + known_hosts and completes options; it self-initializes
    # via _comp_initialize so it's safe to call directly.
    declare -F _comp_cmd_ssh >/dev/null 2>&1 || _completion_loader ssh 2>/dev/null
    declare -F _comp_cmd_ssh >/dev/null 2>&1 && _comp_cmd_ssh "$@"
}
complete -F _ssh_smart ssh

# ----------------------------------------------------------------------------
# wt — worktree navigator (jump is the default).
# First word completes subcommands + worktree names; second word (for go/rm)
# completes worktree names too (for substring matching).
# ----------------------------------------------------------------------------
_wt_completion() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    # Subcommands that take a worktree name as their next arg
    local subcmds="go new list ls rm remove prune help -h --help"

    if [ "$COMP_CWORD" -eq 1 ]; then
        # First arg: subcommands + all worktree names (since jump is default)
        local names
        names="$(_wt_entries 2>/dev/null | awk -F'\t' '{print $1}')"
        COMPREPLY=( $(compgen -W "$subcmds $names" -- "$cur") )
    else
        # Subsequent args: worktree names only (for `wt go`, `wt rm`, etc.)
        local names
        names="$(_wt_entries 2>/dev/null | awk -F'\t' '{print $1}')"
        COMPREPLY=( $(compgen -W "$names" -- "$cur") )
    fi
}
complete -F _wt_completion wt

# ----------------------------------------------------------------------------
# mcporter — MCP CLI & generator (bun global). Completes subcommands,
# `config` subcommands, and server names. Server names are parsed offline from
# the MCP config JSONs (~instant); `mcporter list` pings every server (~2.6s),
# so it is deliberately NOT called on TAB.
# ----------------------------------------------------------------------------
_mcporter_servers() {
    local f
    for f in "$HOME/.claude.json" "$HOME/.config/mcporter/mcporter.json"; do
        [ -r "$f" ] || continue
        node -e '
            var c; try { c = require(process.argv[1]); } catch (e) { process.exit(0); }
            function dump(o){ if (o) Object.keys(o).forEach(function(k){ console.log(k); }); }
            dump(c.mcpServers);
            if (c.projects) Object.keys(c.projects).forEach(function(p){ dump(c.projects[p].mcpServers); });
        ' "$f" 2>/dev/null
    done | sort -u
}

_mcporter() {
    local cur sub
    cur="${COMP_WORDS[COMP_CWORD]}"
    local subcmds="list call resource auth vault record replay generate-cli inspect-cli emit-ts config"
    local cfg_subcmds="list get add remove import login logout doctor"

    # First word: top-level subcommands.
    if [ "$COMP_CWORD" -eq 1 ]; then
        COMPREPLY=( $(compgen -W "$subcmds --help -h" -- "$cur") )
        return 0
    fi

    sub="${COMP_WORDS[1]}"
    case "$sub" in
        config)
            # `mcporter config <TAB>` → config subcommands.
            if [ "$COMP_CWORD" -eq 2 ]; then
                COMPREPLY=( $(compgen -W "$cfg_subcmds --help -h" -- "$cur") )
                return 0
            fi
            # `mcporter config {get|remove|login|logout} <TAB>` → server names.
            case "${COMP_WORDS[2]}" in
                get|remove|login|logout)
                    COMPREPLY=( $(compgen -W "$(_mcporter_servers)" -- "$cur") ); return 0 ;;
                import)
                    COMPREPLY=( $(compgen -W "claude-code cursor vscode" -- "$cur") ); return 0 ;;
            esac
            ;;
        list)
            COMPREPLY=( $(compgen -W "$(_mcporter_servers)" -- "$cur") ); return 0 ;;
        call)
            # Selector is `server.tool` — complete the server half (before any dot).
            COMPREPLY=( $(compgen -W "$(_mcporter_servers)" -- "${cur%%.*}") ); return 0 ;;
        resource|auth|vault)
            COMPREPLY=( $(compgen -W "$(_mcporter_servers)" -- "$cur") ); return 0 ;;
    esac
}
complete -F _mcporter mcporter
