{
  "window.commandCenter": true,
  "cursor.cpp.enablePartialAccepts": true,
  "cursor.composer.shouldAutoScrollToBottom": false,
  "cursor.diffs.useCharacterLevelDiffs": true,
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "explorer.confirmDragAndDrop": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "explorer.confirmDelete": false,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "tailwind-fold.foldStyle": "QUOTES",
  "tailwind-fold.showTailwindImage": false,
  "tailwind-fold.foldLengthThreshold": 50,
  "tailwindCSS.emmetCompletions": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "editor.rulers": [
    80,
    100
  ],
  "python.analysis.packageIndexDepths": [
    {
      "name": "sklearn",
      "depth": 2
    },
    {
      "name": "matplotlib",
      "depth": 2
    },
    {
      "name": "scipy",
      "depth": 2
    },
    {
      "name": "django",
      "depth": 2
    },
    {
      "name": "flask",
      "depth": 2
    },
    {
      "name": "fastapi",
      "depth": 2
    },
    {
      "name": "supabase",
      "depth": 5,
      "includeAllSymbols": true
    }
  ],
  "eslint.workingDirectories": [
    "./app-subdomain",
    "./frontend"
  ],
  "workbench.editor.wrapTabs": true,
  "workbench.colorTheme": "Tomorrow Night Blue",
  "files.autoSave": "afterDelay",
  "files.associations": {
    "*.mmd": "mermaid",
    "*.mermaid": "mermaid"
  },
  "mermaidChart.enableErrorHighlighting": true,
  "mermaidChart.validateOnType": true,
  "cursor.composer.shouldAllowCustomModes": true,
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "diffEditor.maxComputationTime": 0,
  "tailwind-fold.unfoldIfLineSelected": true,
  "update.releaseTrack": "prerelease",
  "remote.autoForwardPortsSource": "hybrid",
  "window.restoreWindows": "none",
  "window.restoreFullscreen": true,
  "gitlens.mode.active": "zen",
  "git.openRepositoryInParentFolders": "never",
  "tailwind-fold.autoFold": false,
  "cursor.composer.queueMessageDefaultBehavior": "queue",
  "cursor.cpp.disabledLanguages": [
    "plaintext"
  ],
  "colorize.colorized_colors": [
    "BROWSERS_COLORS",
    "HEXA",
    "RGB",
    "HSL",
    "OKLAB",
    "OKLCH"
  ],
  "[jsonc]": {
  
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "cursor.general.globalCursorIgnoreList": [
    "**/.env",
    "**/.env.*",
    "**/credentials.json",
    "**/credentials.*.json",
    "**/secret.json",
    "**/secrets.json",
    "**/*.key",
    "**/*.pem",
    "**/*.pfx",
    "**/*.p12",
    "**/*.crt",
    "**/*.cer",
    "**/id_rsa",
    "**/id_dsa",
    "**/.ssh/id_*"
  ],
  "remote.SSH.remotePlatform": {
    "ssh-wsl": "linux",
    "wsl": "linux"
  },
  "remote.forwardOnOpen": false
}