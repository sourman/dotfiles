#!/bin/bash
# Move the active window to the PREVIOUS workspace and follow it.
# Bound to Ctrl+Alt+Shift+Up (workspaces are laid out vertically: Up = previous).
# See move-window-next-ws for why this exists (xfwm4 directional-move quirk).
export DISPLAY="${DISPLAY:-:0}"
cur=$(xdotool get_desktop 2>/dev/null) || exit 0
[ "$cur" -le 0 ] && exit 0
prev=$((cur - 1))
wid=$(xprop -root _NET_ACTIVE_WINDOW 2>/dev/null | awk '{print $5}')
case "$wid" in ''|0x0|'0x00000000') exit 0;; esac
wmctrl -i -r "$wid" -t "$prev" 2>/dev/null
xdotool set_desktop "$prev" 2>/dev/null   # follow the window
