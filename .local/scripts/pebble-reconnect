#!/usr/bin/env bash
#
# pebble-reconnect — background daemon that auto-reconnects the Logitech
# Pebble M350s. Run via the pebble-reconnect.service user unit.
#
# COST MODEL
#   Scans in SHORT BURSTS only while the mouse is DISCONNECTED; idles (cheap
#   status checks, no scanning) while connected. So while you're using the
#   mouse the cost is ~0; only when it's off does it scan, and it backs off
#   to a slow poll after a few minutes.
#
# TUNABLES (seconds)
SCAN_BURST=4      # length of each scan burst
FAST_SLEEP=14     # gap between bursts while recently disconnected (catch within ~SCAN_BURST+this)
SLOW_SLEEP=50     # gap between bursts after disconnected a while (power saving)
SLOW_AFTER=300    # switch to SLOW_SLEEP after this many seconds disconnected
IDLE_SLEEP=20     # re-check interval while connected (status check only — no scanning, no power cost)

NAME='Pebble M350s'
PREFIX='D6:74:42:A3'   # fallback if the name packet isn't captured

now() { date +%s; }
log() { echo "pebble-reconnect: $*"; }

# Is any Pebble currently connected? Echoes its address (looked up by name).
connected_addr() {
  local a
  for a in $(bluetoothctl devices 2>/dev/null | sed -E 's/\x1b\[[0-9;]*m//g' \
             | grep -i "$NAME" | grep -oiE '([0-9A-F]{2}:){5}[0-9A-F]{2}' | sort -u); do
    if bluetoothctl info "$a" 2>/dev/null | grep -qi 'Connected: yes'; then
      echo "$a"; return 0
    fi
  done
}

# One short scan burst; echoes the live Pebble address if it advertised.
scan_addr() {
  local s a; s=$(mktemp)
  timeout "$SCAN_BURST" bluetoothctl scan on > "$s" 2>&1
  a=$(sed -E 's/\x1b\[[0-9;]*m//g' "$s" | grep -i "$NAME" \
      | grep -oiE '([0-9A-F]{2}:){5}[0-9A-F]{2}' | head -1)
  [ -z "$a" ] && a=$(sed -E 's/\x1b\[[0-9;]*m//g' "$s" \
      | grep -oiE "${PREFIX}:[0-9A-F]{2}:[0-9A-F]{2}" | head -1)
  rm -f "$s"; echo "$a"
}

pair_connect() {
  local a="$1"
  bluetoothctl info "$a" 2>/dev/null | grep -qi 'Paired: yes' \
    || bluetoothctl --timeout 25 pair "$a" >/dev/null 2>&1
  bluetoothctl trust "$a" >/dev/null 2>&1
  bluetoothctl --timeout 12 connect "$a" >/dev/null 2>&1
  bluetoothctl info "$a" 2>/dev/null | grep -qi 'Connected: yes'
}

prune_stale() {
  local keep="$1" old
  while IFS= read -r old; do
    [ "$old" = "$keep" ] && continue
    bluetoothctl remove "$old" >/dev/null 2>&1 || true
  done < <(bluetoothctl devices 2>/dev/null | sed -E 's/\x1b\[[0-9;]*m//g' \
           | grep -i "$NAME" | grep -oiE '([0-9A-F]{2}:){5}[0-9A-F]{2}' | sort -u)
}

disco_since=0
prev=""
log "started (scan ${SCAN_BURST}s bursts, only while disconnected)"

while true; do
  cur=$(connected_addr)
  if [ -n "$cur" ]; then
    [ -z "$prev" ] && log "connected ($cur) — idling"
    prev="$cur"; disco_since=0
    sleep "$IDLE_SLEEP"
    continue
  fi

  # --- disconnected ---
  [ -n "$prev" ] && { log "disconnected ($prev) — scanning"; prev=""; }
  [ "$disco_since" = 0 ] && disco_since=$(now)

  addr=$(scan_addr)
  if [ -n "$addr" ]; then
    log "Pebble advertising ($addr) — connecting"
    if pair_connect "$addr"; then
      log "✓ connected ($addr)"
      prune_stale "$addr"
      prev="$addr"; disco_since=0
      sleep 5
      continue
    fi
    log "connect attempt failed ($addr); will retry"
  fi

  if [ $(( $(now) - disco_since )) -gt "$SLOW_AFTER" ]; then
    sleep "$SLOW_SLEEP"
  else
    sleep "$FAST_SLEEP"
  fi
done
