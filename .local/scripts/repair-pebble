#!/usr/bin/env bash
#
# repair-pebble — auto pair & connect the Logitech Pebble M350s over Bluetooth.
#
# WHY THIS EXISTS
#   On this ThinkPad's Intel 8265 BT, Linux does not detect the Pebble's
#   power-on *reconnect* advertisement, so the mouse won't auto-reconnect
#   after being turned off. It DOES advertise in pairing mode, though, and
#   pairing works every time — so this script automates that.
#
# USAGE
#   1. Put the Pebble in PAIRING MODE: hold the bottom button ~3 s until the
#      LED blinks fast.
#   2. Run:  repair-pebble
#
# IDENTIFICATION
#   The Pebble uses a NEW Bluetooth address every time it's put in pairing
#   mode (…:CD:AC → AD → … → AF → B0 → …), so the address is NOT a stable ID.
#   The device NAME ("Pebble M350s") is stable, so we match on that. The
#   address prefix is only a fallback for scan cycles where the name packet
#   (an BLE scan response) isn't captured.
#
set -u

NAME='Pebble M350s'
PREFIX='D6:74:42:A3'                          # fallback only
SCAN_SECS=15
SCAN=$(mktemp)

# All currently-known Pebble addresses (matched by the stable name).
pebble_addrs() {
  bluetoothctl devices 2>/dev/null | sed -E 's/\x1b\[[0-9;]*m//g' \
    | grep -i "$NAME" | grep -oiE '([0-9A-F]{2}:){5}[0-9A-F]{2}' | sort -u
}

# Already connected? Then nothing to do.
for a in $(pebble_addrs); do
  if bluetoothctl info "$a" 2>/dev/null | grep -qi 'Connected: yes'; then
    echo ">> Pebble already connected ($a). Nothing to do."
    rm -f "$SCAN"; exit 0
  fi
done

echo ">> Scanning ${SCAN_SECS}s for the Pebble (pairing mode = fast-blinking LED)…"
timeout "$SCAN_SECS" bluetoothctl scan on > "$SCAN" 2>&1
clean() { sed -E 's/\x1b\[[0-9;]*m//g' "$SCAN"; }

# Live Pebble address: try the (stable) name first; fall back to address prefix.
ADDR=$(clean | grep -i "$NAME" | grep -oiE '([0-9A-F]{2}:){5}[0-9A-F]{2}' | head -1)
if [ -z "$ADDR" ]; then
  ADDR=$(clean | grep -oiE "${PREFIX}:[0-9A-F]{2}:[0-9A-F]{2}" | head -1)
  [ -n "$ADDR" ] && echo ">> (name not captured this cycle; matched by prefix $ADDR)"
fi
rm -f "$SCAN"

if [ -z "$ADDR" ]; then
  echo "!! No Pebble advertising. Hold the bottom button ~3s until the LED"
  echo "   blinks fast (pairing mode), then re-run this script."
  exit 1
fi

echo ">> Found Pebble at $ADDR — pairing / trusting / connecting…"
bluetoothctl info "$ADDR" 2>/dev/null | grep -qi 'Paired: yes' \
  || bluetoothctl --timeout 25 pair "$ADDR" >/dev/null 2>&1
bluetoothctl trust "$ADDR" >/dev/null 2>&1
bluetoothctl --timeout 12 connect "$ADDR" >/dev/null 2>&1

if bluetoothctl info "$ADDR" 2>/dev/null | grep -qi 'Connected: yes'; then
  echo ">> ✓ Connected. Pebble ready at $ADDR"
else
  echo ">> ✗ Couldn't connect this time. Re-run once more."
  exit 1
fi

# Prune stale Pebble bonds (the address changes every pairing, so old ones are
# dead weight). Matched by name; never removes the one we just connected.
while IFS= read -r old; do
  [ "$old" = "$ADDR" ] && continue
  bluetoothctl remove "$old" >/dev/null 2>&1 || true
done < <(pebble_addrs)

exit 0
